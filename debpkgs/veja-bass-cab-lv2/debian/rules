#!/usr/bin/make -f
export DH_VERBOSE = 1
export QUILT_PATCHES = debian/patches

%:
	dh $@ --with quilt

override_dh_auto_configure:

override_dh_auto_build:
	$(MAKE)

override_dh_auto_install:
	$(MAKE) install \
		DESTDIR=$(CURDIR)/debian/veja-bass-cab-lv2 \
		PREFIX=/usr
	cp -r veja-bass-cab.lv2/modgui \
		$(CURDIR)/debian/veja-bass-cab-lv2/usr/lib/lv2/veja-bass-cab.lv2/

override_dh_auto_test:
