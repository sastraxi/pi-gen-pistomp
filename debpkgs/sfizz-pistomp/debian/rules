#!/usr/bin/make -f

# Limit parallelism to avoid OOM (C++ templates are memory-hungry)
PARALLEL_JOBS := $(shell nproc | awk '{j=int($$1/2); print (j>4)?4:(j<1)?1:j}')

%:
	dh $@ --buildsystem=cmake --with quilt

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DPLUGIN_LV2=ON \
		-DPLUGIN_LV2_UI=OFF \
		-DPLUGIN_VST3=OFF \
		-DPLUGIN_PUREDATA=OFF \
		-DSFIZZ_JACK=OFF \
		-DSFIZZ_RENDER=ON \
		-DSFIZZ_USE_SYSTEM_LV2=ON \
		-DSFIZZ_USE_SYSTEM_ABSEIL=OFF \
		-DSFIZZ_USE_SYSTEM_PUGIXML=OFF

override_dh_auto_build:
	dh_auto_build -- -j$(PARALLEL_JOBS)
