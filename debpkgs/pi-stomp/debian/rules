#!/usr/bin/make -f
export DH_VERBOSE=1

PKG=pi-stomp
PISTOMP_SRC_DIR=$(CURDIR)/../pi-stomp-src
VENV_DIR=$(CURDIR)/debian/$(PKG)/opt/pistomp/venvs/pi-stomp
SRC_INSTALL_DIR=$(CURDIR)/debian/$(PKG)/opt/pistomp/pi-stomp

%:
	dh $@

override_dh_auto_clean:
	# pi-stomp has pyproject.toml which can trigger python-distutils
	# detection in compat 12+. We don't need to clean anything.
	true

override_dh_auto_test:
	# No tests to run in the build environment.
	true

override_dh_auto_configure:
	# Clone pi-stomp source if not already present
	if [ ! -d "$(PISTOMP_SRC_DIR)" ]; then \
		git clone --branch pistomp-v3 --depth 1 \
			https://github.com/TreeFallSound/pi-stomp.git \
			"$(PISTOMP_SRC_DIR)"; \
	fi

override_dh_auto_build:
	# Venv uses system Python3 (/usr/bin/python3 exists on target, no --copies needed)
	uv venv --python /usr/bin/python3 --system-site-packages "$(VENV_DIR)"
	# Sync dependencies; --no-editable installs the wheel into site-packages
	UV_PROJECT_ENVIRONMENT="$(VENV_DIR)" \
		uv sync --frozen --no-dev --no-editable --extra hardware \
		--project "$(PISTOMP_SRC_DIR)"

override_dh_auto_install:
	# Install source tree
	mkdir -p "$(SRC_INSTALL_DIR)"
	cp -a "$(PISTOMP_SRC_DIR)"/* "$(SRC_INSTALL_DIR)/"
	# Remove git metadata to keep the package clean
	rm -rf "$(SRC_INSTALL_DIR)"/.git
	# Install systemd service file
	install -Dm 644 debian/pi-stomp.mod-ala-pi-stomp.service \
		$(CURDIR)/debian/pi-stomp/lib/systemd/system/mod-ala-pi-stomp.service

override_dh_installsystemd:
	# Service enablement is handled by stage2/05-pistomp/01-run.sh ln -sf,
	# not by deb-systemd-helper. The unit file is installed manually above.
