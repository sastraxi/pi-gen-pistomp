# pi-gen build-time image settings only (upstream pi-gen convention).
# Sourced by build.sh and build-docker.sh; validated for IMG_NAME/RELEASE.
#
# Configuration is split across three files by audience:
#   - this file:        image build settings (name, release, locale, user account)
#   - config.sh:        upstream URLs, branches, version pins for custom .deb packages
#                       (set -a auto-exports every var into build.sh / fetch-packages.sh
#                       / debian/rules)
#   - stage2/05-pistomp/files/pistomp.conf:
#                       runtime/user-facing settings (WiFi, hostname, password,
#                       timezone, JACK_SAMPLE_RATE, JACK_PERIOD) — applied by
#                       firstboot.sh on first boot, NOT baked in at build time.

IMG_NAME='pistompOS'
RELEASE=trixie
DEPLOY_COMPRESSION="none"

LOCALE_DEFAULT="en_US.UTF-8"
KEYBOARD_KEYMAP=us

FIRST_USER_NAME="pistomp"

# Account is locked until firstboot.sh sets the password from pistomp.conf.
# FIRST_USER_PASS is intentionally unset here.
DISABLE_FIRST_BOOT_USER_RENAME=1
ENABLE_SSH=1
ENABLE_CLOUD_INIT=0
